<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>都更管家 - 權益試算系統</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root { --primary-color: #2c3e50; --secondary-color: #d35400; --bg-color: #f4f7f6; }
        body { font-family: "Microsoft JhengHei", sans-serif; background-color: var(--bg-color); padding: 15px; }
        .container { max-width: 650px; margin: auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .header { text-align: center; border-bottom: 2px solid var(--primary-color); padding-bottom: 15px; margin-bottom: 20px; }
        .project-title { background: #e8f4f8; padding: 12px; border-radius: 6px; font-weight: bold; color: #2980b9; text-align: center; margin-bottom: 20px; border: 1px solid #bde0ef; }
        
        /* 參數欄位：淡橘色背景，文字改為黑色 */
        .admin-config { background: #fff3e0; padding: 20px; border-radius: 8px; margin-bottom: 20px; font-size: 0.95em; border: 1px dashed #e67e22; }
        .config-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; }
        .config-item { border-bottom: 1px solid rgba(230, 126, 34, 0.2); padding: 5px 0; color: black; }
        
        .input-group { margin-bottom: 18px; }
        label { display: block; margin-bottom: 6px; font-weight: bold; color: #34495e; }
        .input-flex { display: flex; gap: 8px; }
        input { flex: 1; padding: 12px; border: 1px solid #ccc; border-radius: 6px; font-size: 16px; }
        select { width: 90px; border: 1px solid #ccc; border-radius: 6px; background: #f9f9f9; cursor: pointer; }
        
        button { width: 100%; padding: 15px; background: var(--primary-color); color: white; border: none; border-radius: 8px; font-size: 18px; cursor: pointer; transition: 0.2s; }
        button:hover { background: #1a252f; }
        .btn-download { background: #27ae60; margin-top: 15px; }

        /* 警告區域：文字改粗體 */
        .warning { background: #fff5f5; color: #c0392b; padding: 15px; border-radius: 8px; border-left: 5px solid #c0392b; margin: 20px 0; font-size: 0.9em; line-height: 1.6; font-weight: bold; }
        
        .result-box { margin-top: 25px; display: none; border: 2px solid #eee; border-radius: 10px; overflow: hidden; background: white; }
        .result-header { background: #fdf2e9; padding: 12px; border-bottom: 1px solid #eee; font-weight: bold; color: var(--secondary-color); text-align: center; }
        .result-item { display: flex; justify-content: space-between; padding: 12px 15px; border-bottom: 1px solid #f9f9f9; }
        .result-item:last-child { border-bottom: none; background: #fff9f5; }
        .result-label { color: #555; }
        .result-value { font-weight: bold; color: #2c3e50; }
        .highlight-value { color: #c0392b; font-size: 1.2em; }

        .footer { margin-top: 30px; text-align: center; border-top: 1px solid #eee; padding-top: 20px; }
        .footer a { display: block; color: #3498db; text-decoration: none; margin: 10px 0; font-weight: bold; font-size: 0.95em; }
    </style>
</head>
<body>

<div class="container" id="capture-content">
    <div class="header">
        <h2 style="margin:0;">🏠 都更管家權益試算系統</h2>
    </div>

    <div class="project-title">新北市新店區新和段177地號</div>

    <div class="admin-config">
        <strong>⚙️ 專案開發目前參數設定</strong>
        <div class="config-grid">
            <div class="config-item">1. 基地面積: 986.15 坪</div>
            <div class="config-item">2. 容積率: 280%</div>
            <div class="config-item">3. 土地預估坪效: 6.743</div>
            <div class="config-item">4. 預估房價: 80 萬/坪</div>
            <div class="config-item">5. 共負成本: 35 萬/坪</div>
            <div class="config-item">6. 公設比: 30%</div>
        </div>
    </div>

    <div class="input-group">
        <label>1. 土地持份面積</label>
        <div class="input-flex">
            <input type="number" id="in-land" placeholder="請參考權狀" step="0.01">
            <select id="unit-land"><option value="ping">坪</option><option value="m2">m²</option></select>
        </div>
    </div>
    <div class="input-group">
        <label>2. 原專有面積 (不含陽台)</label>
        <div class="input-flex">
            <input type="number" id="in-indoor" placeholder="純室內坪數" step="0.01">
            <select id="unit-indoor"><option value="ping">坪</option><option value="m2">m²</option></select>
        </div>
    </div>
    <div class="input-group">
        <label>3. 原專有面積 (含陽台公設) = 權狀面積</label>
        <div class="input-flex">
            <input type="number" id="in-total" placeholder="權狀總登記坪數" step="0.01">
            <select id="unit-total"><option value="ping">坪</option><option value="m2">m²</option></select>
        </div>
    </div>
    
    <div class="input-group">
        <label>目前房價單價預估 (萬/坪) 註：用於計算增值，也可輸入原取得房屋成本單價</label>
        <input type="number" id="in-old-price" value="45" step="1">
    </div>

    <div class="warning">
        ⚠️ 重要警告<br>
        坪效權值需以【都更審議核准】為準。本工具試算結果僅供參考，實際實施內容仍以官方審查核定版本為準。
    </div>

    <button onclick="calculate()">產生分析報告</button>

    <div id="result" class="result-box">
        <div class="result-header">📊 試算報告結果</div>
        <div class="result-item"><span class="result-label">1. 最終分回面積(新權狀面積)</span><span class="result-value" id="res1"></span></div>
        <div class="result-item"><span class="result-label">2. 新室內面積 (含陽台)</span><span class="result-value" id="res2"></span></div>
        <div class="result-item"><span class="result-label">3. 新室內面積 (不含陽台)</span><span class="result-value" id="res3"></span></div>
        <div class="result-item"><span class="result-label">4. 室內面積分回比率</span><span class="result-value" id="res4"></span></div>
        <div class="result-item"><span class="result-label">5. 權狀面積分回比率</span><span class="result-value" id="res5"></span></div>
        <div class="result-item"><span class="result-label">6. 更新前價值</span><span class="result-value" id="res6"></span></div>
        <div class="result-item"><span class="result-label">7. 更新後價值</span><span class="result-value" id="res7"></span></div>
        <div class="result-item"><span class="result-label">8. 預估資產增值金額</span><span class="result-value highlight-value" id="res8"></span></div>
    </div>

    <div class="footer">
        <p style="margin-bottom:10px; font-weight:bold; color:var(--primary-color);">📢 專業都更諮詢</p>
        <a href="https://www.facebook.com/yachirenew" target="_blank">🔗 都更管家雅琪 粉絲專頁</a>
        <a href="https://www.facebook.com/groups/639437535895888/" target="_blank">💬 自主自辦都更,危老重建討論區-《都更危老解碼室》</a>
    </div>

    <button class="btn-download" id="btn-dl" style="display:none;" onclick="takeScreenshot()">💾 下載試算報告圖片</button>
</div>

<script>
function toPing(val, unit) {
    if (!val) return 0;
    return unit === 'm2' ? val * 0.3025 : val;
}

function calculate() {
    // 177地號 精確參數
    const landEff = 6.743;
    const pubRatio = 0.3;
    const costPerPing = 350000;
    const priceAfter = 800000;

    // 住戶輸入
    const uLand = toPing(parseFloat(document.getElementById('in-land').value), document.getElementById('unit-land').value);
    const uOldIndoor = toPing(parseFloat(document.getElementById('in-indoor').value), document.getElementById('unit-indoor').value);
    const uOldTotal = toPing(parseFloat(document.getElementById('in-total').value), document.getElementById('unit-total').value);
    const priceBefore = parseFloat(document.getElementById('in-old-price').value) * 10000;

    if (uLand <= 0 || uOldIndoor <= 0 || uOldTotal <= 0) {
        alert("請輸入正確的面積數值"); return;
    }

    // --- 核心計算 (與 Excel 一致) ---
    const targetArea = uLand * landEff;
    const burden = targetArea * costPerPing;
    const offsetPing = burden / priceAfter;
    
    // 1. 最終分回面積(新權狀面積)
    const finalNewDeed = targetArea - offsetPing;
    
    // 2. 新室內面積 (含陽台) = 新權狀 * (1 - 0.3)
    const newIndoorWithBalcony = finalNewDeed * (1 - pubRatio);
    
    // 3. 新室內面積 (不含陽台) = 含陽台 * 0.9 (根據Excel數據回推)
    const newIndoorPure = newIndoorWithBalcony * 0.9;
    
    // 4. 室內面積分回比率 = 新不含陽台 / 原不含陽台
    const indoorRatio = (newIndoorPure / uOldIndoor) * 100;
    
    // 5. 權狀面積分回比率 = 新權狀 / 原總權狀
    const deedRatio = (finalNewDeed / uOldTotal) * 100;
    
    // 6. 更新前價值
    const valBefore = uOldTotal * priceBefore;
    
    // 7. 更新後價值
    const valAfter = finalNewDeed * priceAfter;
    
    // 8. 增值金額
    const profit = valAfter - valBefore;

    // 填寫結果
    document.getElementById('res1').innerText = finalNewDeed.toFixed(2) + " 坪";
    document.getElementById('res2').innerText = newIndoorWithBalcony.toFixed(2) + " 坪";
    document.getElementById('res3').innerText = newIndoorPure.toFixed(2) + " 坪";
    document.getElementById('res4').innerText = indoorRatio.toFixed(1) + " %";
    document.getElementById('res5').innerText = deedRatio.toFixed(1) + " %";
    document.getElementById('res6').innerText = Math.round(valBefore/10000).toLocaleString() + " 萬元";
    document.getElementById('res7').innerText = Math.round(valAfter/10000).toLocaleString() + " 萬元";
    document.getElementById('res8').innerText = Math.round(profit/10000).toLocaleString() + " 萬元";

    document.getElementById('result').style.display = 'block';
    document.getElementById('btn-dl').style.display = 'block';
    document.getElementById('result').scrollIntoView({ behavior: 'smooth' });
}

function takeScreenshot() {
    const target = document.getElementById('capture-content');
    html2canvas(target, { scale: 2, backgroundColor: "#f4f7f6" }).then(canvas => {
        const link = document.createElement('a');
        link.download = '都更管家-試算報告.png';
        link.href = canvas.toDataURL();
        link.click();
    });
}
</script>
</body>
</html>
